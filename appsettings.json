{
  "Application": {
    "Name": "Nexus ERP",
    "Version": "1.0.0"
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "MultiTenancy": {
    "Strategy": "Schema"
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },


  "HealthChecks": {
    "Enabled": true,
    "Path": "/health"
  }
}